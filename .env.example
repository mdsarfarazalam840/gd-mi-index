# Required - Google OAuth Configuration
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/callback

# Optional - If you already have tokens (get these from OAuth flow)
# GOOGLE_ACCESS_TOKEN=your_access_token_here
# GOOGLE_REFRESH_TOKEN=your_refresh_token_here

# Application Configuration
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your_nextauth_secret_here_generate_with_openssl_rand_base64_32

# Optional: Redis for caching (production)
# REDIS_URL=redis://localhost:6379

# Optional: Custom configuration
MAX_FILE_SIZE=5368709120
ITEMS_PER_PAGE=50

# Optional
TMDB_API_KEY=your_tmdb_api_key_here
